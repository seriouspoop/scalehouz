---
/** Sticky stacking service cards. Each expands its deliverables on click (site.js). */
---
<section id="services" data-screen-label="Services">
  <div class="sec-head light" style="max-width:1180px">
    <span class="kicker reveal">// Services</span>
    <h2 class="reveal" data-d="1">Everything a D2C brand needs to scale.</h2>
  </div>
  <div class="stack">
    <article class="scard" style="--acc:var(--sh-cyan); --cv:linear-gradient(140deg, #00BCF2 0%, #06485c 60%, #08222c 100%)">
      <div class="s-left">
        <span class="s-cat">Service · 01</span>
        <h3>D2C Brand Architecture</h3>
        <p class="s-desc">Build memorable consumer brands through strategic positioning, cohesive identity systems, packaging that commands attention, and launch strategies designed for long-term growth.</p>
        <div class="s-pills"><span>Brand Strategy</span><span>Identity Systems</span><span>Packaging Strategy</span><span>Go-to-Market</span></div>
        <button class="s-explore" data-cursor aria-expanded="false">Explore deliverables <span class="ar">→</span></button>
      </div>
      <div class="s-canvas">
        <div class="cv-grain"></div>
        <div class="cv-blob" style="width:280px;height:280px;background:#7de9ff;top:-40px;left:-30px;--bx:14px;--by:10px"></div>
        <div class="cv-blob" style="width:220px;height:220px;background:var(--sh-amber);bottom:-50px;right:-20px;opacity:.4;--bx:-12px;--by:-10px"></div>
        <div class="cv-top"><span class="cv-tag">Positioning · identity · packaging</span><span class="cv-arrow">↗</span></div>
        <span class="cv-num">01</span>
      </div>
      <div class="s-details"><div class="s-details-in"><div class="s-caps">
        <div class="cap"><span class="cap-n">01</span><h4>Brand Strategy</h4><ul><li>Audience Research</li><li>Brand Direction</li><li>Consumer Insights</li><li>Brand Foundations</li></ul></div>
        <div class="cap"><span class="cap-n">02</span><h4>Identity Systems</h4><ul><li>Visual Identity</li><li>Brand Guidelines</li><li>Design Language</li><li>Brand Consistency</li></ul></div>
        <div class="cap"><span class="cap-n">03</span><h4>Packaging Strategy</h4><ul><li>Packaging Direction</li><li>Shelf Presence</li><li>Consumer Perception</li><li>Packaging Systems</li></ul></div>
        <div class="cap"><span class="cap-n">04</span><h4>Go-to-Market</h4><ul><li>Launch Strategy</li><li>Market Positioning</li><li>Communication Framework</li><li>Growth Roadmap</li></ul></div>
      </div></div></div>
    </article>
    <article class="scard" style="--acc:var(--sh-amber); --cv:linear-gradient(140deg, #F18E31 0%, #b23d12 55%, #4a1606 100%)">
      <div class="s-left">
        <span class="s-cat">Service · 02</span>
        <h3>D2C Digital Experience</h3>
        <p class="s-desc">Fast, premium digital experiences — brand and e-commerce websites plus high-converting landing pages, engineered to turn attention into measurable growth.</p>
        <div class="s-pills"><span>Websites</span><span>Landing Pages</span><span>E-commerce</span><span>Conversion</span></div>
        <button class="s-explore" data-cursor aria-expanded="false">Explore deliverables <span class="ar">→</span></button>
      </div>
      <div class="s-canvas">
        <div class="cv-grain"></div>
        <div class="cv-blob" style="width:300px;height:300px;background:#ffd27a;top:-60px;right:-40px;--bx:-14px;--by:12px"></div>
        <div class="cv-blob" style="width:220px;height:220px;background:var(--sh-magenta);bottom:-50px;left:-30px;opacity:.4;--bx:12px;--by:-10px"></div>
        <div class="cv-top"><span class="cv-tag">Websites · landing · e-commerce</span><span class="cv-arrow">↗</span></div>
        <span class="cv-num">02</span>
      </div>
      <div class="s-details"><div class="s-details-in"><div class="s-caps">
        <div class="cap"><span class="cap-n">01</span><h4>Websites</h4><ul><li>Brand Websites</li><li>Corporate Websites</li><li>E-commerce Websites</li><li>Responsive Development</li><li>UX/UI Design</li><li>CMS &amp; Custom Development</li></ul></div>
        <div class="cap"><span class="cap-n">02</span><h4>Landing Pages</h4><ul><li>Product Launch Pages</li><li>Marketing Campaign Pages</li><li>High-Converting Sales Pages</li><li>Lead Generation Pages</li><li>Event &amp; Webinar Pages</li><li>Conversion Optimization</li></ul></div>
      </div></div></div>
    </article>
    <article class="scard" style="--acc:var(--sh-magenta); --cv:linear-gradient(140deg, #EC008C 0%, #8a1258 55%, #2e0a24 100%)">
      <div class="s-left">
        <span class="s-cat">Service · 03</span>
        <h3>D2C Content &amp; Authority</h3>
        <p class="s-desc">Build cultural authority with sharp positioning, always-on social, standout production, and creator partnerships that compound reach over time.</p>
        <div class="s-pills"><span>Strategy</span><span>Social</span><span>Production</span><span>Creator Partnerships</span></div>
        <button class="s-explore" data-cursor aria-expanded="false">Explore deliverables <span class="ar">→</span></button>
      </div>
      <div class="s-canvas">
        <div class="cv-grain"></div>
        <div class="cv-blob" style="width:300px;height:300px;background:#ff5fbd;top:-50px;left:-40px;--bx:14px;--by:10px"></div>
        <div class="cv-blob" style="width:220px;height:220px;background:var(--sh-cyan);bottom:-60px;right:-30px;opacity:.4;--bx:-12px;--by:-12px"></div>
        <div class="cv-top"><span class="cv-tag">Strategy · social · production</span><span class="cv-arrow">↗</span></div>
        <span class="cv-num">03</span>
      </div>
      <div class="s-details"><div class="s-details-in"><div class="s-caps">
        <div class="cap"><span class="cap-n">01</span><h4>Strategy</h4><ul><li>Brand Positioning</li><li>Content Strategy</li><li>Consumer Research</li><li>Editorial Planning</li></ul></div>
        <div class="cap"><span class="cap-n">02</span><h4>Social</h4><ul><li>Social Management</li><li>Platform Growth</li><li>Community Building</li><li>Content Distribution</li></ul></div>
        <div class="cap"><span class="cap-n">03</span><h4>Production</h4><ul><li>Creative Direction</li><li>Photography</li><li>Video Production</li><li>Short-form Content</li></ul></div>
        <div class="cap"><span class="cap-n">04</span><h4>Creator Partnerships</h4><ul><li>Creator Sourcing</li><li>Campaign Planning</li><li>Talent Management</li><li>Performance Reporting</li></ul></div>
      </div></div></div>
    </article>
  </div>
</section>
