---
/** Closing CTA → isolated onboarding route. Button is magnetic (site.js). */
---

<section id="cta" data-screen-label="Work With Us">
  <span class="kicker reveal">// Work with us</span>
  <h2 class="reveal" data-d="1" id="cta-headline">
    Your growth, in thoughtful hands.
  </h2>
  <p class="reveal" data-d="2">
    One conversation is enough to know if we fit. Real conversations, real
    solutions — we reply within a day.
  </p>
  <div id="magnet-zone" class="reveal" data-d="2">
    <a class="btn-primary" id="magnet" href="/onboarding" data-cursor
      >START A PROJECT</a
    >
  </div>
</section>
