---
/** Contact / footer. */
---

<footer id="contact" data-screen-label="Footer">
  <div class="f-divider"></div>
  <div class="f-grid">
    <div>
      <h2>
        Real conversations,<br />real solutions<span
          style="color:var(--sh-amber)">.</span
        >
      </h2>
      <a class="link-quiet" href="mailto:business@scalehouz.com" data-cursor
        >business@scalehouz.com</a
      >
    </div>
    <div class="f-col">
      <span class="kicker">Socials</span>
      <a
        href="https://www.instagram.com/scale.houz/"
        data-cursor
        aria-label="Instagram"
        target="_blank">Instagram</a
      >
      <a
        href="https://linkedin.com/company/scale-houz"
        data-cursor
        aria-label="LinkedIn"
        target="_blank">LinkedIn</a
      >
      <a
        href="https://x.com/scalehouz"
        data-cursor
        aria-label="X"
        target="_blank">X</a
      >
    </div>
    <div class="f-col">
      <span class="kicker">Studio</span>
      <span>Working worldwide,<br />rooted in real problems.</span>
    </div>
  </div>
  <div class="f-bottom">
    <img src="/assets/logo/scale_houz.svg" alt="Scale Houz" loading="lazy" />
    <div class="words">
      <span>Build</span><span>Scale</span><span>Lead</span><span>Impact</span>
    </div>
    <span>© 2026 Scale Houz.</span>
  </div>
</footer>
