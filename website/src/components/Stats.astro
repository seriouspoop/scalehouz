---
/** Client-score + counters. Numbers count up on scroll (site.js). */
---
<section id="stats" data-screen-label="Stats">
  <div class="stats-grid">
    <div class="score reveal">
      <span class="big" data-count="9.8" data-dec="1">0.0</span>
      <span class="den">/ 10.0<br />client score</span>
    </div>
    <div class="stats-copy reveal" data-d="1">
      <span class="kicker" style="color:var(--sh-gray-500)">// Brand excellence</span>
      <p style="margin-top:14px">Years of building high-performance brands, scalable systems, and conversion-focused experiences — with trust at the core.</p>
      <div class="counters">
        <div class="counter"><div class="n"><span data-count="42">0</span>%</div><div class="l">Avg. conversion lift</div></div>
        <div class="counter"><div class="n"><span data-count="3">0</span>×</div><div class="l">Faster to launch</div></div>
        <div class="counter"><div class="n">$<span data-count="18">0</span>M</div><div class="l">Client revenue moved</div></div>
      </div>
    </div>
  </div>
</section>
