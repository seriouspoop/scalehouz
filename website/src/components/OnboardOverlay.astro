---
/**
 * Intent splash. Personalises the hero copy via localStorage (see site.js).
 * Non-gating: all page content is rendered in the static HTML below it, so
 * search bots crawl every heading, paragraph, and link regardless. The overlay
 * auto-dismisses (6s) and is skipped entirely for returning visitors.
 */
---
<section id="onboard" data-screen-label="Onboarding" aria-label="Welcome">
  <img class="ob-item" src="/assets/logo/scale_houz.svg" alt="Scale Houz" style="animation-delay:.1s" />
  <p class="ob-item ob-title" style="animation-delay:.35s">What brings you here?</p>
  <div id="ob-options" class="ob-item" style="animation-delay:.6s" role="group" aria-label="What brings you here?">
    <button class="ob-opt" data-cursor data-intent="brand">Build a brand</button>
    <button class="ob-opt" data-cursor data-intent="marketing">Scale marketing</button>
    <button class="ob-opt" data-cursor data-intent="design">Design</button>
    <button class="ob-opt" data-cursor data-intent="website">Website</button>
    <button class="ob-opt" data-cursor data-intent="explore">Just exploring</button>
  </div>
</section>
